entity = {
	name = "bmp2_entity"
	pdxmesh = "SOV_BMP2_mesh"

	state = { name = "idle"				animation = "idle"   animation_blend_time = 0.3 }
	state = { name = "move"				animation = "move"   animation_blend_time = 0.3
		event = { time = 0 node="exhaust" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="left_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="right_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes }
		event = { trigger_once = yes sound = { soundeffect = "utility_move_animation" } }
	}
	state = { name = "retreat"				animation = "move"   animation_blend_time = 0.3
		event = { time = 0 node="exhaust" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="left_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="right_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes }
		event = { trigger_once = yes sound = { soundeffect = "utility_move_animation" } }
	}
	state = { name = "attack"			animation = "attack" animation_blend_time = 0.3
		event = { time = 0 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes sound = { soundeffect = 2A42_gun } }
		event = { time = 0.10 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.20 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.30 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.40 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.50 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.60 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.70 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.70 node="gun" particle = "light_tank_attack_barrel_smoke_particle"  keep_particle = yes }
	}
	state = { name = "defend"			animation = "attack" animation_blend_time = 0.3
		event = { time = 0 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes sound = { soundeffect = 2A42_gun } }
		event = { time = 0.10 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.20 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.30 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.40 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.50 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.60 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.70 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.70 node="gun" particle = "light_tank_attack_barrel_smoke_particle"  keep_particle = yes }
	}
	state = { name = "support_attack"	animation = "attack" animation_blend_time = 0.3
		event = { time = 0 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes sound = { soundeffect = 2A42_gun } }
		event = { time = 0.10 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.20 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.30 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.40 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.50 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.60 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.70 node="gun" particle = "light_tank_attack_barrel_particle"  keep_particle = yes }
		event = { time = 0.70 node="gun" particle = "light_tank_attack_barrel_smoke_particle"  keep_particle = yes }
	}
	state = { name = "training"				animation = "idle" 			animation_blend_time = 0.3 animation_speed = 1.0
	event = { time = 0 node="exhaust" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
	}
	scale = 0.8
}
	

entity = {
	name = "SOV_MD4_light_armor_entity_5"
	pdxmesh = "SOV_light_tank_Sprut_SD_mesh"

	state = { name = "idle"				animation = "idle"   animation_blend_time = 0.3 }
	state = { name = "move"				animation = "move"   animation_blend_time = 0.3

		event = { time = 0 node="exhaust_1" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="exhaust_2" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="left_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="right_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes }
		event = { trigger_once = yes sound = { soundeffect = "tank_engine_light_move" } }
	}

	state = { name = "retreat"				animation = "move"   animation_blend_time = 0.3

		event = { time = 0 node="exhaust_1" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="exhaust_2" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="left_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node="right_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes }
		event = { trigger_once = yes sound = { soundeffect = "tank_engine_light_move" } }
	}
	state = { name = "attack"			animation = "attack" animation_blend_time = 0.3

		event = { time = 0 node="gun_muzzle1" particle = "light_tank_attack_barrel_particle"  keep_particle = yes   light = "mg_muzzle_flash" sound = { soundeffect = heavy_armour_fire } }
		event = { time = 0 node="gun_muzzle1" particle = "light_tank_attack_barrel_smoke_particle"  keep_particle = yes   }
		event = { time = 1.4 node="gun_muzzle2" particle = "mg_muzzle_particle"  keep_particle = yes   light = "mg_muzzle_flash" }
		event = { time = 1.4 node="gun_muzzle2" particle = "mg_muzzle_smoke_particle"  keep_particle = yes   light = "mg_muzzle_flash" }
	}
	state = { name = "defend"			animation = "attack" animation_blend_time = 0.3
		event = { time = 0 node="gun_muzzle1" particle = "light_tank_attack_barrel_particle"  keep_particle = yes   light = "mg_muzzle_flash" sound = { soundeffect = heavy_armour_fire } }
		event = { time = 0 node="gun_muzzle1" particle = "light_tank_attack_barrel_smoke_particle"  keep_particle = yes   }
		event = { time = 1.4 node="gun_muzzle2" particle = "mg_muzzle_particle"  keep_particle = yes   light = "mg_muzzle_flash" }
		event = { time = 1.4 node="gun_muzzle2" particle = "mg_muzzle_smoke_particle"  keep_particle = yes   light = "mg_muzzle_flash" }
	}
	state = { name = "support_attack"	animation = "attack" animation_blend_time = 0.3
		event = { time = 0 node="gun_muzzle1" particle = "light_tank_attack_barrel_particle"  keep_particle = yes   light = "mg_muzzle_flash" sound = { soundeffect = heavy_armour_fire } }
		event = { time = 0 node="gun_muzzle1" particle = "light_tank_attack_barrel_smoke_particle"  keep_particle = yes   }
		event = { time = 1.4 node="gun_muzzle2" particle = "mg_muzzle_particle"  keep_particle = yes   light = "mg_muzzle_flash" }
		event = { time = 1.4 node="gun_muzzle2" particle = "mg_muzzle_smoke_particle"  keep_particle = yes   light = "mg_muzzle_flash" }
	}
	state = { name = "training"				animation = "attack" 			animation_blend_time = 0.3 animation_speed = 1.0
		event = { time = 0 node="gun_muzzle1" particle = "light_tank_attack_barrel_particle"  keep_particle = yes   light = "mg_muzzle_flash" sound = { soundeffect = heavy_armour_fire } }
		event = { time = 0 node="gun_muzzle1" particle = "light_tank_attack_barrel_smoke_particle"  keep_particle = yes   }
		event = { time = 1.4 node="gun_muzzle2" particle = "mg_muzzle_particle"  keep_particle = yes   light = "mg_muzzle_flash" }
		event = { time = 1.4 node="gun_muzzle2" particle = "mg_muzzle_smoke_particle"  keep_particle = yes   light = "mg_muzzle_flash" }
	}
	scale = 0.9

}


